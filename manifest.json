{
  "manifest_version": 3,
  "name": "Neo Peek Clone",
  "version": "1.0.1",
  "description": "Neo Browser stílusú link előnézet iframe segítségével.",
  "permissions": [
    "declarativeNetRequest"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "content.js"
      ],
      "css": [
        "styles.css"
      ]
    }
  ]
}