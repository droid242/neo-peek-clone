{
  "manifest_version": 3,
  "name": "Neo Peek Clone",
  "version": "2.0.1",
  "description": "Neo Browser-style link preview via iframe.",
  "permissions": [
    "declarativeNetRequest"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "content.js"
      ],
      "css": [
        "styles.css"
      ]
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "pic/peek.svg",
        "pic/w.svg",
        "pic/x.svg"
      ],
      "matches": [
        "<all_urls>"
      ]
    }
  ]
}